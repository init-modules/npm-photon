{
	"name": "@init-modules/website-builder",
	"version": "0.1.0",
	"description": "Foundation runtime and editing primitives for the package-first website builder.",
	"type": "module",
	"files": [
		"dist",
		"src"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"typesVersions": {
		"*": {
			"client": [
				"./dist/client.d.ts"
			],
			"sdk": [
				"./dist/sdk.d.ts"
			],
			"forms": [
				"./dist/forms.d.ts"
			],
			"public": [
				"./dist/public.d.ts"
			],
			"server": [
				"./dist/server.d.ts"
			],
			"shared": [
				"./dist/shared.d.ts"
			]
		}
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.js",
			"default": "./dist/client.js"
		},
		"./sdk": {
			"types": "./dist/sdk.d.ts",
			"import": "./dist/sdk.js",
			"default": "./dist/sdk.js"
		},
		"./forms": {
			"types": "./dist/forms.d.ts",
			"import": "./dist/forms.js",
			"default": "./dist/forms.js"
		},
		"./public": {
			"types": "./dist/public.d.ts",
			"import": "./dist/public.js",
			"default": "./dist/public.js"
		},
		"./shared": {
			"types": "./dist/shared.d.ts",
			"import": "./dist/shared.js",
			"default": "./dist/shared.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js",
			"default": "./dist/server.js"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts src/client.ts src/sdk.ts src/forms.ts src/public.tsx src/server.ts src/shared.ts --format esm --dts --clean",
		"check:dist": "npm run build && git diff --exit-code -- dist",
		"prepack": "npm run build"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"dependencies": {
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-select": "^2.2.6",
		"@dnd-kit/core": "^6.3.1",
		"@tiptap/extension-placeholder": "^2.26.4",
		"@tiptap/html": "^2.26.4",
		"@tiptap/react": "^2.26.4",
		"@tiptap/starter-kit": "^2.26.4",
		"clsx": "^2.1.1",
		"idb": "^8.0.3",
		"lucide-react": "^0.556.0",
		"sonner": "^2.0.7",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"tsup": "^8.5.0",
		"typescript": "^5.9.3"
	}
}
